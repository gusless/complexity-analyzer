{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "build projeto",
			"command": "C:\\MinGW\\bin\\g++.exe",
			"args": [
				"-std=gnu++17",
				"-g",
				"-Wall",
				"-Wextra",
				"src/*.cpp",
				"-I",
				"include",
				"-o",
				"output/main.exe"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$gcc"
			]
		}
	]
}